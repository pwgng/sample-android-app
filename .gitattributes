# Set default behavior to automatically normalize line endings.
* text=auto

# Force LF for source files and configuration
*.kt text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.gradle text eol=lf
*.kts text eol=lf
*.properties text eol=lf
*.toml text eol=lf
*.md text eol=lf

# Binary files - should not be touched
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
*.aar binary
